    uuid id
    str name
    enum type
    bool is_locked
    datetime created_at
  }
  role ||--|| admin_user : "rel"
  role ||--|| permission : "rel"
  permission {
    str key
    str group
    str label
  }
  role_permission {
    ref role_id
    ref permission_key
  }
  role_permission ||--|| role : "rel"
  role_permission ||--|| permission : "rel"
  admin_session {
    uuid id
    ref admin_id
    str token_id
    str ip
    str device
    enum status
    datetime last_active_at
    datetime created_at
  }
  admin_session ||--|| admin_user : "rel"
